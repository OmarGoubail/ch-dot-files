#!/bin/bash
set -euo pipefail

# ==============================================================================
# secure-server — Firewall management for Hetzner VPS
# ==============================================================================
# Usage:
#   sudo secure-server lockdown     Lock everything. SSH via Tailscale only.
#   sudo secure-server cloudflare   Add HTTPS access for Cloudflare IPs.
#   sudo secure-server status       Show current firewall rules.
# ==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# --- Cloudflare IPs (https://www.cloudflare.com/ips/) ---
CLOUDFLARE_IPV4=(
    173.245.48.0/20
    103.21.244.0/22
    103.22.200.0/22
    103.31.4.0/22
    141.101.64.0/18
    108.162.192.0/18
    190.93.240.0/20
    188.114.96.0/20
    197.234.240.0/22
    198.41.128.0/17
    162.158.0.0/15
    104.16.0.0/13
    104.24.0.0/14
    172.64.0.0/13
    131.0.72.0/22
)

CLOUDFLARE_IPV6=(
    2400:cb00::/32
    2606:4700::/32
    2803:f800::/32
    2405:b500::/32
    2405:8100::/32
    2a06:98c0::/29
    2c0f:f248::/32
)

# --- Helpers ---

preflight() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}Run as root: sudo secure-server $1${NC}"
        exit 1
    fi

    if ! command -v tailscale &>/dev/null; then
        echo -e "${RED}Tailscale is not installed.${NC}"
        exit 1
    fi

    if ! tailscale status &>/dev/null; then
        echo -e "${RED}Tailscale is not connected. Run 'sudo tailscale up' first.${NC}"
        exit 1
    fi
}

harden_ssh() {
    echo "==> Hardening SSH..."
    SSHD_CONFIG="/etc/ssh/sshd_config"

    # Disable password authentication
    if grep -q "^PasswordAuthentication" "$SSHD_CONFIG"; then
        sed -i 's/^PasswordAuthentication.*/PasswordAuthentication no/' "$SSHD_CONFIG"
    else
        echo "PasswordAuthentication no" >> "$SSHD_CONFIG"
    fi

    # Disable root login
    if grep -q "^PermitRootLogin" "$SSHD_CONFIG"; then
        sed -i 's/^PermitRootLogin.*/PermitRootLogin no/' "$SSHD_CONFIG"
    else
        echo "PermitRootLogin no" >> "$SSHD_CONFIG"
    fi

    systemctl restart sshd
}

# ==============================================================================
# lockdown — Tailscale SSH only, everything else denied
# ==============================================================================
cmd_lockdown() {
    preflight "lockdown"

    TAILSCALE_IP=$(tailscale ip -4)
    echo -e "${GREEN}Tailscale connected.${NC} This machine: $TAILSCALE_IP"
    echo ""
    echo -e "${YELLOW}This will lock down the server to Tailscale SSH only.${NC}"
    echo -e "${YELLOW}No public web traffic will be allowed.${NC}"
    echo -e "${YELLOW}Use 'tailscale funnel <port>' to share apps temporarily.${NC}"
    echo ""
    read -p "Are you SSH'd in via Tailscale right now? (yes/no): " CONFIRM
    if [ "$CONFIRM" != "yes" ]; then
        echo "Aborted. Connect via Tailscale first."
        exit 1
    fi

    echo "==> Resetting firewall..."
    ufw --force reset

    ufw default deny incoming
    ufw default allow outgoing

    # SSH from Tailscale only (CGNAT range)
    echo "==> Allowing SSH from Tailscale only..."
    ufw allow from 100.64.0.0/10 to any port 22 proto tcp

    echo "==> Enabling firewall..."
    ufw --force enable

    harden_ssh

    echo ""
    echo -e "${GREEN}=========================================${NC}"
    echo -e "${GREEN}  Server locked down.${NC}"
    echo -e "${GREEN}=========================================${NC}"
    echo ""
    echo "  SSH (22):    Tailscale only"
    echo "  Web:         DENIED (use 'tailscale funnel <port>' for temp access)"
    echo "  Everything:  DENIED"
    echo ""
    echo "  SSH hardened: no passwords, no root login"
    echo ""
    echo -e "${YELLOW}  Test Tailscale SSH in a NEW terminal before closing this one!${NC}"
    echo ""
    echo -e "${BLUE}  When you're ready for production with a domain:${NC}"
    echo -e "${BLUE}    sudo secure-server cloudflare${NC}"
    echo ""
}

# ==============================================================================
# cloudflare — Add HTTPS from Cloudflare IPs on top of lockdown
# ==============================================================================
cmd_cloudflare() {
    preflight "cloudflare"

    # Check if already locked down
    if ! ufw status | grep -q "22/tcp.*ALLOW.*100.64.0.0/10"; then
        echo -e "${YELLOW}Server isn't locked down yet. Running lockdown first...${NC}"
        echo ""
        cmd_lockdown
        echo ""
    fi

    echo "==> Adding Cloudflare HTTPS rules..."

    # Allow HTTPS from Cloudflare IPv4
    for ip in "${CLOUDFLARE_IPV4[@]}"; do
        ufw allow from "$ip" to any port 443 proto tcp
    done

    # Allow HTTPS from Cloudflare IPv6
    for ip in "${CLOUDFLARE_IPV6[@]}"; do
        ufw allow from "$ip" to any port 443 proto tcp
    done

    # Also allow HTTP for cert challenges / redirects
    for ip in "${CLOUDFLARE_IPV4[@]}"; do
        ufw allow from "$ip" to any port 80 proto tcp
    done
    for ip in "${CLOUDFLARE_IPV6[@]}"; do
        ufw allow from "$ip" to any port 80 proto tcp
    done

    ufw reload

    echo ""
    echo -e "${GREEN}=========================================${NC}"
    echo -e "${GREEN}  Cloudflare access enabled.${NC}"
    echo -e "${GREEN}=========================================${NC}"
    echo ""
    echo "  SSH (22):    Tailscale only"
    echo "  HTTP (80):   Cloudflare only"
    echo "  HTTPS (443): Cloudflare only"
    echo "  Everything:  DENIED"
    echo ""
    echo -e "${BLUE}  Next steps on Cloudflare:${NC}"
    echo "    1. Add your domain to Cloudflare"
    echo "    2. DNS A record → $(curl -s4 ifconfig.me) (proxy ON, orange cloud)"
    echo "    3. SSL/TLS → Full (Strict)"
    echo ""
}

# ==============================================================================
# status — Show current firewall rules
# ==============================================================================
cmd_status() {
    echo -e "${BLUE}==> Firewall status${NC}"
    ufw status verbose
    echo ""

    echo -e "${BLUE}==> Tailscale status${NC}"
    if command -v tailscale &>/dev/null && tailscale status &>/dev/null; then
        echo -e "  IP: ${GREEN}$(tailscale ip -4)${NC}"
        echo -e "  Status: ${GREEN}connected${NC}"
    else
        echo -e "  Status: ${RED}not connected${NC}"
    fi
    echo ""

    echo -e "${BLUE}==> SSH config${NC}"
    SSHD_CONFIG="/etc/ssh/sshd_config"
    PASS_AUTH=$(grep "^PasswordAuthentication" "$SSHD_CONFIG" 2>/dev/null || echo "PasswordAuthentication (default)")
    ROOT_LOGIN=$(grep "^PermitRootLogin" "$SSHD_CONFIG" 2>/dev/null || echo "PermitRootLogin (default)")
    echo "  $PASS_AUTH"
    echo "  $ROOT_LOGIN"
    echo ""
}

# ==============================================================================
# Main
# ==============================================================================
case "${1:-}" in
    lockdown)
        cmd_lockdown
        ;;
    cloudflare)
        cmd_cloudflare
        ;;
    status)
        cmd_status
        ;;
    *)
        echo "secure-server — Firewall management for your VPS"
        echo ""
        echo -e "Usage: sudo secure-server ${GREEN}<command>${NC}"
        echo ""
        echo "Commands:"
        echo -e "  ${GREEN}lockdown${NC}     Lock everything down. SSH via Tailscale only."
        echo -e "               Use 'tailscale funnel <port>' to share apps."
        echo ""
        echo -e "  ${GREEN}cloudflare${NC}   Open HTTPS to Cloudflare IPs. Run this when you"
        echo -e "               have a domain pointed at this server."
        echo ""
        echo -e "  ${GREEN}status${NC}       Show current firewall rules and server state."
        echo ""
        ;;
esac
