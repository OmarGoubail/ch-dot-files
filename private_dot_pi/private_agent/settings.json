{
  "lastChangelogVersion": "0.80.3",
  "defaultProvider": "fireworks",
  "defaultModel": "accounts/fireworks/models/glm-5p2",
  "npmCommand": ["/opt/homebrew/bin/npm"],
  "packages": [
    "npm:pi-web-access",
    "npm:pi-vim",
    "npm:pi-notify",
    "npm:@ff-labs/pi-fff@0.8.1",
    "npm:pi-hashline-edit",
    "npm:pi-subagents",
    "npm:pi-elixir",
    "npm:pi-context",
    "npm:pi-btw"
  ],
  "defaultThinkingLevel": "high",
  "pi-codex-fast": {
    "enabled": false
  },
  "subagents": {
    "disableBuiltins": false
  },
  "theme": "theme-current",
  "extensions": ["extensions/dannote"],
  "confirmActionGroups": {
    "execution": false
  },
  "oracle": {
    "model": "openai-codex-personal/gpt-5.6-sol",
    "thinking": "xhigh",
    "confirm": true,
    "defaultIntent": "verify",
    "tools": "none",
    "context": {
      "maxTokens": 18000,
      "summary": "latest",
      "keepTailTokens": 6000,
      "keepUserTurns": 5,
      "keepAssistantTurns": 4,
      "drop": {
        "thinking": true,
        "toolResults": "errors-and-small",
        "toolCalls": "names-only",
        "bashOutput": "truncate",
        "images": true,
        "customMessages": true
      },
      "truncate": {
        "toolResultChars": 1600,
        "bashOutputChars": 1600,
        "assistantTextChars": 4000
      }
    },
    "budget": {
      "targetOutputTokens": 2000,
      "maxTotalUsd": 1
    },
    "prompt": {
      "costWarning": true,
      "style": "review"
    },
    "restore": {
      "model": true,
      "thinking": true,
      "tools": true
    }
  }
}
