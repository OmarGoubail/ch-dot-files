import { basename, dirname } from "node:path";
import type { ExtensionAPI } from "@earendil-works/pi-coding-agent";

type Status = "ready" | "running" | "done";

const MAX_TITLE_LENGTH = 96;
const DONE_VISIBLE_MS = 4500;

function clean(text: string) {
  return text
    .replace(/[\u0000-\u001f\u007f]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function truncate(text: string, max: number) {
  const cleaned = clean(text);
  return cleaned.length > max ? `${cleaned.slice(0, Math.max(0, max - 1))}…` : cleaned;
}

function projectLabel(cwd: string) {
  const project = basename(cwd) || "project";
  const parent = basename(dirname(cwd));

  // Zed-created worktrees often look like ../worktrees/<repo>/<worktree>/<repo>.
  // Include the generated worktree name so notifications are distinguishable.
  if (cwd.includes("/worktrees/") && parent && parent !== project) {
    return `${project}/${parent}`;
  }

  return project;
}

function statusIcon(status: Status) {
  switch (status) {
    case "running":
      return "🏃";
    case "done":
      return "🔔";
    case "ready":
      return "💤";
  }
}

function buildTitle(status: Status, cwd: string, _prompt?: string, branch?: string) {
  const workspace = projectLabel(cwd);
  const scope = branch ? `${workspace}/${branch}` : workspace;

  // Zed terminal threads do not currently expose a custom terminal/process icon API.
  // Keep a compact π mark in the title as the fallback Pi identity.
  return truncate(`${statusIcon(status)}  π  ›  ${scope}`, MAX_TITLE_LENGTH);
}

function writeTerminalTitle(title: string) {
  // OSC 2 sets the terminal title. Zed Terminal Threads use this in the sidebar
  // and in the notification generated by a terminal bell.
  process.stdout.write(`\x1b]2;${title}\x07`);
}

function ringTerminalBell() {
  // Zed Terminal Threads turn terminal bells from unfocused threads into notifications.
  process.stdout.write("\x07");
}

export default function (pi: ExtensionAPI) {
  let cwd = process.cwd();
  let branch: string | undefined;
  let lastPrompt: string | undefined;
  let runId = 0;
  let readyTimer: ReturnType<typeof setTimeout> | undefined;

  function clearReadyTimer() {
    if (readyTimer) {
      clearTimeout(readyTimer);
      readyTimer = undefined;
    }
  }

  async function refreshBranch() {
    const result = await pi.exec("git", ["branch", "--show-current"], { cwd }).catch(() => undefined);
    branch = result?.stdout.trim() || undefined;
  }

  function setStatus(status: Status, prompt = lastPrompt) {
    writeTerminalTitle(buildTitle(status, cwd, prompt, branch));
  }

  function scheduleReady(expectedRunId: number) {
    clearReadyTimer();
    readyTimer = setTimeout(() => {
      if (runId === expectedRunId) {
        setStatus("ready", undefined);
      }
    }, DONE_VISIBLE_MS);
  }

  pi.on("session_start", async (_event, ctx) => {
    clearReadyTimer();
    cwd = ctx.cwd;
    branch = undefined;
    lastPrompt = undefined;
    await refreshBranch();
    setStatus("ready", undefined);
  });

  pi.on("before_agent_start", async (event, ctx) => {
    clearReadyTimer();
    runId += 1;
    cwd = ctx.cwd;
    lastPrompt = event.prompt;
    await refreshBranch();
    setStatus("running", event.prompt);
  });

  pi.on("agent_start", async () => {
    clearReadyTimer();
    setStatus("running");
  });

  pi.on("agent_end", async () => {
    const completedRunId = runId;
    setStatus("done");
    ringTerminalBell();
    scheduleReady(completedRunId);
  });

  pi.on("session_shutdown", async () => {
    clearReadyTimer();
  });
}
