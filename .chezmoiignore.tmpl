.pi/agent/run-history.jsonl
.pi/elixir

{{- if eq .chezmoi.os "darwin" }}
# macOS: skip server-only files
.local/bin/secure-server
{{- end }}

{{- if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") (eq .chezmoi.osRelease.id "arch") }}
# On Arch + Omarchy, Omarchy owns the base idle/lock/sunset configs.
# We manage hyprland.conf plus our override files.
.config/hypr/hypridle.conf
.config/hypr/hyprlock.conf
.config/hypr/hyprsunset.conf
{{- end }}

{{- if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") (eq .chezmoi.osRelease.id "ubuntu") }}
# Server: skip all desktop configs
.config/aerospace
.config/alacritty
.config/ghostty
.config/hypr
.config/kitty
.config/kmonad
.config/mako
.config/opencode
.config/opensessions
.config/swayosd
.config/walker
.config/waybar
.config/wezterm
.config/worktrunk
.config/zed
.config/zellij
.config/graphite
.config/uv
{{- end }}
