theme = tokyonight 
font-size = 10.5
font-family = "JetBrainsMono Nerd Font Mono"

shell-integration = fish

copy-on-select = clipboard

# Mouse scrolling - reduce speed for tmux compatibility
# Default is discrete:3,precision:0.1, lower values = slower scrolling
mouse-scroll-multiplier = discrete:1,precision:0.5

gtk-titlebar = false 

clipboard-read = "allow"
clipboard-paste-protection = false

window-decoration = true

background-opacity = 0.7
background-blur = true
background-blur-radius = 20	 

confirm-close-surface = false


cursor-style = block


keybind = shift+enter=text:\x1b
