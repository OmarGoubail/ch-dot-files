    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "open iex",
    "command": "iex -S mix",
    "args": [],
    "env": {},
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "pi",
    "command": "pi",
    "args": [],
    "env": {},
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "hooks": ["create_worktree"],
    "reveal": "always"
  },
  {
    "label": "create_worktree",
    "command": "if command -q wt; and test -n \"$ZED_WORKTREE_ROOT\"; and test -n \"$ZED_MAIN_GIT_WORKTREE\"; and test \"$ZED_WORKTREE_ROOT\" != \"$ZED_MAIN_GIT_WORKTREE\"; cd \"$ZED_WORKTREE_ROOT\"; and wt step copy-ignored; end",
    "args": [],
    "env": {},
    "shell": { "program": "/opt/homebrew/bin/fish" },
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success"
  }
]
