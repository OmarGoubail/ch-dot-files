onboarding = false

[terminal]
shell_mode = "auto"
new_cwd = "follow"

[theme]
name = "{{ $herdrThemeFile := joinPath .chezmoi.homeDir ".config/theme/herdr" }}{{ output "sh" "-c" (printf "cat %s 2>/dev/null || printf terminal" ($herdrThemeFile | quote)) | trim }}"

[keys]
prefix = "ctrl+a"
help = "prefix+?"
settings = "prefix+shift+s"
detach = "prefix+q"
reload_config = "prefix+shift+r"
open_notification_target = "prefix+o"
workspace_picker = "prefix+w"
goto = ["prefix+s", "prefix+g"]

new_workspace = "prefix+shift+n"
rename_workspace = "prefix+shift+w"
close_workspace = "prefix+shift+d"
previous_workspace = "prefix+shift+left"
next_workspace = "prefix+shift+right"
switch_workspace = "cmd+1..9"
new_worktree = "prefix+shift+g"
open_worktree = "prefix+shift+o"
remove_worktree = "prefix+alt+d"

new_tab = "prefix+c"
rename_tab = "prefix+comma"
previous_tab = "prefix+p"
next_tab = "prefix+n"
switch_tab = "prefix+1..9"
close_tab = "prefix+shift+x"

rename_pane = "prefix+shift+p"
edit_scrollback = "prefix+e"
copy_mode = "prefix+["
focus_pane_left = "prefix+h"
focus_pane_down = "prefix+j"
focus_pane_up = "prefix+k"
focus_pane_right = "prefix+l"
cycle_pane_next = ["prefix+tab", "ctrl+tab"]
cycle_pane_previous = ["prefix+shift+tab", "ctrl+shift+tab"]
split_vertical = ["prefix+|", "prefix+v"]
split_horizontal = "prefix+minus"
close_pane = "prefix+x"
zoom = ["prefix+m", "prefix+z"]
resize_mode = "prefix+r"
toggle_sidebar = "prefix+b"
focus_agent = "prefix+alt+1..9"

# Navigate mode stays vi-like when explicitly opened.
navigate_workspace_up = "up"
navigate_workspace_down = "down"
navigate_pane_left = "h"
navigate_pane_down = "j"
navigate_pane_up = "k"
navigate_pane_right = "l"

[ui]
sidebar_width = 32
sidebar_min_width = 18
sidebar_max_width = 36
mouse_capture = true
redraw_on_focus_gained = false
confirm_close = true
prompt_new_tab_name = true
show_agent_labels_on_pane_borders = true
agent_panel_scope = "all"
accent = "cyan"

[ui.toast]
delivery = "system"

[ui.sound]
enabled = false

[session]
resume_agents_on_restore = true

[experimental]
allow_nested = false
kitty_graphics = false
pane_history = false

[advanced]
scrollback_limit_bytes = 104857600
